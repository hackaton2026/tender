# ==============================
# Tender Environment Variables
# ==============================

# ==============================
# Database Configuration
# ==============================
POSTGRES_USER=tender
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=tender
POSTGRES_PORT=5432
DATABASE_URL=postgresql://tender:your_secure_password_here@postgres:5432/tender

# ==============================
# Application Configuration
# ==============================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Port Configuration
APP_PORT=3000
API_PORT=3001

# ==============================
# CORS Configuration
# ==============================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ==============================
# Authentication
# ==============================
# Choose one of: clerk, authjs, local
AUTH_PROVIDER=local
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# Clerk (if using Clerk)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# ==============================
# Video Storage
# ==============================
# Choose one of: local, mux, cloudflare, s3
VIDEO_STORAGE_PROVIDER=local
VIDEO_STORAGE_PATH=./uploads/videos

# Mux (if using Mux)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Cloudflare Stream (if using Cloudflare)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# AWS S3 (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ==============================
# Video Processing
# ==============================
MAX_VIDEO_SIZE_MB=100
MAX_VIDEO_DURATION_SECONDS=180
SUPPORTED_VIDEO_FORMATS=mp4,mov,webm

# ==============================
# Content Moderation
# ==============================
ENABLE_CONTENT_MODERATION=false
CONTENT_MODERATION_PROVIDER=

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================
# Email Configuration
# ==============================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@tender.example.com

# ==============================
# Analytics
# ==============================
ENABLE_ANALYTICS=false
ANALYTICS_PROVIDER=

# ==============================
# Logging
# ==============================
LOG_LEVEL=info
LOG_FORMAT=json

# ==============================
# Coolify / Hosting Configuration
# ==============================
# These are typically set by Coolify during deployment
COOLIFY_APP_ID=
COOLIFY_DOMAIN=
